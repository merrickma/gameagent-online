{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gameagent-online",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gameagent-online","database_id": "7a277ac2-fdc2-421a-b08e-cf46684f2319",
			// Run `wrangler d1 create my-emdash-site` and paste the ID here
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "gameagent-online","preview_bucket_name": "gameagent-online",
		},
	],
	"observability": {
		"enabled": true,
	},
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}